# Blueprint Configuration Example
# Copy this file to ~/.blueprint.yaml or ./.blueprint.yaml and customize

# Database configuration
database:
  path: ~/.blueprint/blueprint.db

# Source system configurations
sources:
  max:
    db_path: ~/Project/experiments/max/max.db
  graph:
    path: ~/Project/experiments/graph
  github:
    token_env: GITHUB_TOKEN
    default_owner:
    default_repo:

# LLM configuration
llm:
  provider: anthropic
  default_model: claude-opus-4-6  # or claude-sonnet-4-5
  # Set ANTHROPIC_API_KEY environment variable for API access

# Export configuration
exports:
  output_dir: ~/blueprint-exports
  formats:
    relay: json
    smoothie: markdown
    codex: markdown
    claude_code: markdown
    csv-tasks: csv
  templates:
    # Optional markdown templates. Paths may be absolute or relative to this config file.
    # Main templates can use {brief.field}, {plan.field}, and {tasks}.
    # Task templates can also use {task.field}.
    smoothie:
      # path: ./templates/smoothie.md
      # task_path: ./templates/task.md
    codex:
      # path: ./templates/codex.md
      # task_path: ./templates/task.md
    claude_code:
      # path: ./templates/claude-code.md
      # task_path: ./templates/task.md
